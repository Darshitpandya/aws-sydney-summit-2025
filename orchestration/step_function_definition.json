{
  "Comment": "Post-Proton Deployment Orchestration",
  "StartAt": "TagResources",
  "States": {
    "TagResources": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:<REGION>:<ACCOUNT_ID>:function:TagLambda",
      "Next": "NotifySlack"
    },
    "NotifySlack": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:<REGION>:<ACCOUNT_ID>:function:NotifyLambda",
      "End": true
    }
  }
}
